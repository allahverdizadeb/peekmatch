# Copy this file to .env and fill in real values. Never commit .env itself.

# Powers CV/vacancy matching, the CV Change Plan, cover letter, Interview Playbook, and OCR.
# Without it, every AI-backed function falls back to a deterministic offline placeholder so the
# rest of the app stays testable/demoable without a key.
OPENAI_API_KEY=
# Falls back to gpt-5.6-terra if unset.
OPENAI_MODEL=gpt-5.6-terra

# SQLite path — defaults to file:./dev.db if unset.
DATABASE_URL=

# Shared secret gating GET /api/suggestions and the frontend /admin, /admin/insights pages.
ADMIN_KEY=

PORT=4000

# Optional — overrides the Chromium executable path used for vacancy-URL rendering. Unset, falls
# back to Playwright's own auto-detected local install.
PLAYWRIGHT_CHROMIUM_PATH=

# ---------- Superadmin dashboard (/superadmin) ----------

# One-time bootstrap credentials for the single Superadmin account — read ONLY when explicitly
# running `npm run admin:bootstrap`, never on ordinary server startup. Remove both from your
# environment immediately after running the script once; they are never read again after that.
SUPERADMIN_EMAIL=
SUPERADMIN_INITIAL_PASSWORD=

# Comma-separated list of frontend origins allowed to make state-changing /api/admin/* requests,
# e.g. "https://peek-match.com,https://www.peek-match.com" — set this explicitly in production.
# Unset, only plain-http localhost/127.0.0.1 origins are accepted (safe for local dev only).
ADMIN_ALLOWED_ORIGINS=

# Presence alone marks the Payriff payment provider as "connected" for System Health/Payments
# status display — the actual Payriff integration is not implemented in this codebase yet.
PAYRIFF_API_KEY=
