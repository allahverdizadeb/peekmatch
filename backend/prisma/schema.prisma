// PeekMatch — CV/vacancy matching platform
// Prisma schema: analyses (CV + vacancy + AI result) and orders (one-time package purchases)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Analysis {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  expiresAt DateTime

  // Anonymous-session ownership (no user registration exists in this product — see
  // AnonymousSession below). Nullable so pre-migration rows remain readable (treated as
  // ownerless/public, matching their pre-migration behavior) — every newly-created analysis always
  // gets one via the session middleware.
  anonymousSessionId String?
  anonymousSession    AnonymousSession? @relation(fields: [anonymousSessionId], references: [id], onDelete: SetNull)

  // Paid-entitlement window, anchored to the FIRST successful payment for this analysis — separate
  // from `expiresAt` (the CV/vacancy *data retention* clock, which starts at creation for a free
  // analysis). Set once, atomically, the first time any Order for this analysis reaches 'paid';
  // later package upgrades do not reset it. See lib/pricing.ts's isEntitlementActive().
  paidAt               DateTime?
  entitlementExpiresAt DateTime?

  // CV input
  cvMode     String? // 'file' | 'text'
  cvFileName String?
  cvMimeType String?
  cvSizeBytes Int?
  cvText     String? // extracted / pasted CV text

  // Vacancy input
  vacancySource   String? // 'url' | 'manual'
  vacancyUrl      String?
  vacancyStatus   String  @default("idle") // idle | loading | success | failed
  vacancyFailReason String?
  vacancyTitle    String?
  vacancyCompany  String?
  vacancyLocation String?
  vacancyDomain   String?
  vacancyText     String? // extracted or manually pasted requirements text

  outputLanguage String  @default("az") // az | en
  consent        Boolean @default(false)

  // Processing
  status      String @default("draft") // draft | processing | done | failed
  procStage   Int    @default(0) // 0..6
  failReason  String?

  // AI result (free + paid derived content), stored as JSON
  resultJson         String? // matching analysis result (incl. cvPresentationScore)
  reportJson          String? // unused — /report is derived directly from resultJson, see analyses.ts
  cvChangePlanJson    String? // CV Change Plan (evidence-based rewrite/add/clarify/remove cards) — generated eagerly for every analysis, full list gated by unlocksApplication
  interviewPrepJson   String? // paid: Interview Playbook content

  // Interview Playbook generation job status — persisted (not just in-memory) so it survives a
  // server restart and so "processing" vs "failed" is a real, queryable fact rather than inferred
  // from an HTTP response. idle -> processing -> done | failed. A failed job can be retried, which
  // flips it back to processing; interviewPrepJson (above) is the actual result, set only on done.
  interviewPrepStatus     String  @default("idle") // idle | processing | done | failed
  interviewPrepFailReason String?

  // Lifecycle
  deletedAt                DateTime? // set by user-triggered delete; content fields nulled at the same time
  selfAttestedGapConfirmed Boolean?  // user's yes/no answer to "do you actually have this experience?" for mostImportantMissingRequirement
  selfAttestedGapDetails   String?   // free-text elaboration captured when the answer is "yes"

  // @deprecated — Cover Letter feature removed (product update). No longer read/written by any
  // application code; kept as-is rather than dropped to avoid a destructive migration on rows that
  // may still hold generated content (they self-expire within 24h regardless via the existing
  // retention cron, so this is safe to actually drop in a later cleanup pass once confirmed unused).
  coverLetterJson String?

  // @deprecated — CV Recheck feature removed (product update). Same non-destructive rationale as
  // coverLetterJson above: no longer read/written anywhere, left in place rather than dropped.
  recheckCvText     String?
  recheckResultJson String?
  recheckCount      Int     @default(0)

  orders         Order[]
  recoveryTokens RecoveryToken[]

  @@index([expiresAt])
  @@index([anonymousSessionId])
}

// Identifies "this browser" without registration — see middleware/anonymousSession.ts. The raw
// token only ever exists in the HttpOnly cookie on the client and in transit; only its SHA-256
// hash is stored here, so a database read can never yield a usable session token.
model AnonymousSession {
  id         String   @id @default(uuid())
  tokenHash  String   @unique
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())
  expiresAt  DateTime // sliding window, refreshed on use — deliberately longer-lived than any one
  // analysis's own 24h entitlement, since the session represents the returning browser, not a
  // single purchase.

  analyses Analysis[]

  @@index([expiresAt])
}

model Order {
  id         String   @id @default(uuid())
  createdAt  DateTime @default(now())
  paidAt     DateTime?
  analysisId String
  analysis   Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  package   Int // 1 = Application Package (CV Change Plan + Evidence Chain), 2 = Interview Ready Package (adds Interview Playbook)
  amountUsd Float
  status    String @default("pending") // pending | processing | paid | failed | refunded

  // Superadmin analytics / payment-ops fields (additive, non-breaking) — a provider-neutral shape
  // prepared for a future real Payriff integration. `provider` is null for every row created via the
  // pre-existing demo `/orders/:id/simulate` flow (see routes/orders.ts) — Superadmin financial KPIs
  // (lib/kpi.ts) deliberately only ever count `provider: 'payriff'` rows, so simulated/demo orders
  // never surface as real revenue in the dashboard, now or later. Once Payriff is wired up, real
  // orders get `provider: 'payriff'` and start counting automatically — no separate toggle needed.
  publicReference        String?   @unique // masked-display reference, e.g. "PM-7F3A9C21" — see lib/masking.ts
  provider                String? // null = simulated/demo; 'payriff' once a real integration exists
  providerTransactionRef  String?
  providerFeeAmount       Float?  // null = unknown/unavailable; NEVER estimated from a public commission %
  checkoutStartedAt       DateTime?
  failedAt                DateTime?
  refundedAt              DateTime?
  refundAmountUsd         Float   @default(0)
  failureCode             String? // safe allowlisted category, never a raw provider error string

  @@index([analysisId])
  @@index([status])
  @@index([createdAt])
  @@index([provider])
}

// Single-purpose "return to my paid analysis" link, sent by email after a successful payment (see
// routes/recovery.ts). Only the hash of the raw token is stored — same rationale as
// AnonymousSession.tokenHash — so the link itself is the only place the usable secret ever exists.
// consumedAt is intentionally NOT set on use (see routes/recovery.ts) — the token stays valid
// (re-openable, e.g. from multiple devices or repeat email opens) until the analysis's own
// entitlement expires; it is a bounded-lifetime bookmark, not a one-time-use credential.
model RecoveryToken {
  id         String   @id @default(uuid())
  tokenHash  String   @unique
  analysisId String
  analysis   Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  expiresAt  DateTime // mirrors Analysis.entitlementExpiresAt at issuance time

  @@index([analysisId])
}

// Minimal first-party product-analytics event log (no CV/document content, only ids/counts/booleans).
model Event {
  id         String   @id @default(uuid())
  createdAt  DateTime @default(now())
  name       String
  analysisId String?
  metadata   String? // JSON-encoded, small fixed key allowlist per event — see routes/events.ts

  // Superadmin analytics fields (additive) — see SUPERADMIN_ANALYTICS_EVENTS.md / routes/events.ts.
  // visitorRef/webSessionRef are plain opaque strings, NOT Prisma relations — this keeps analytics
  // history independent of AnonymousSession's own lifecycle (no cascade/null-out if a future session
  // cleanup job is added), and neither is ever client-supplied — both are derived server-side from
  // req.sessionId / the ingestion helper in lib/analyticsIngest.ts.
  eventId        String?  @unique // idempotency key (client- or server-generated)
  visitorRef     String? // = AnonymousSession.id
  webSessionRef  String? // derived 30-min-inactivity grouping id
  packageCode    String? // 'package_1' | 'package_2' — see lib/pricing.ts's packageCode()
  language       String? // 'az' | 'en'
  deviceCategory String? // 'desktop' | 'mobile' | 'tablet' — coarse UA bucket only, never fingerprinting
  path           String? // pathname only, never a full URL or query string
  referrerDomain String? // hostname only, never a full referrer URL
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  source         String   @default("client") // 'client' | 'server' — which ingestion path wrote it

  @@index([name])
  @@index([createdAt])
  @@index([visitorRef])
  @@index([webSessionRef])
}

// Single Superadmin operator account (email + password). Deliberately one account, no roles/teams —
// see CLAUDE.md-equivalent product brief: no 2FA, no invitations, no multi-admin management at launch.
model SuperadminUser {
  id                String    @id @default(uuid())
  email             String    @unique
  passwordHash      String
  passwordAlgo      String    @default("bcrypt")
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  lastLoginAt       DateTime?
  passwordChangedAt DateTime  @default(now())
  failedLoginCount  Int       @default(0)
  lockedUntil       DateTime?

  sessions SuperadminSession[]
}

// Server-side Superadmin session — the raw token exists only in the HttpOnly `__Host-pm_admin_session`
// cookie in transit; only its hash is ever stored here (same pattern as AnonymousSession.tokenHash).
// idleExpiresAt slides on activity (30 min); absoluteExpiresAt is set once at creation and never
// extended (12h) — see middleware/superadminAuth.ts.
model SuperadminSession {
  id                String    @id @default(uuid())
  superadminUserId  String
  superadminUser    SuperadminUser @relation(fields: [superadminUserId], references: [id], onDelete: Cascade)
  tokenHash         String    @unique
  csrfSecret        String
  createdAt         DateTime  @default(now())
  lastActivityAt    DateTime  @default(now())
  idleExpiresAt     DateTime
  absoluteExpiresAt DateTime
  revokedAt         DateTime?
  userAgentSummary  String? // short derived summary (browser+OS), never the raw full UA string
  requestIdHash     String? // masked/hashed request identifier — never a raw IP address

  @@index([superadminUserId])
  @@index([idleExpiresAt])
}

// Append-only audit trail for every Superadmin action (login, export, settings change, ...). No
// update/delete code path exists anywhere for this model by design.
model AdminAuditLog {
  id            String   @id @default(uuid())
  createdAt     DateTime @default(now())
  actorId       String? // null for a failed login attempt (no authenticated actor yet)
  actorEmail    String? // snapshot at time of action — survives actor record changes
  action        String // fixed allowlist — see lib/auditLog.ts
  status        String // 'success' | 'failure'
  metadata      String? // JSON, allowlisted per action
  requestIdHash String? // masked/hashed request identifier — never a raw IP address

  @@index([createdAt])
  @@index([actorId])
  @@index([action])
}

// Pre-aggregated hourly/daily metric buckets — idempotent overwrite-by-bucket, populated by the
// existing 15-min cron (see index.ts). `dimension` uses "" (not null) for the ungrouped total so the
// @@unique constraint below actually enforces one-row-per-bucket under SQLite (which treats NULL as
// distinct-from-NULL in unique indexes). The KPI service (lib/kpi.ts) currently prefers live indexed
// queries over reading this table at this product's current volume — this table exists so the
// aggregation requirement is real, running infrastructure rather than a stub, and is a
// straightforward later optimization to switch reads onto once real volume justifies it.
model MetricRollup {
  id          String   @id @default(uuid())
  granularity String // 'hour' | 'day'
  bucketStart DateTime // UTC-aligned bucket start
  metricKey   String
  dimension   String   @default("")
  value       Float
  updatedAt   DateTime @updatedAt

  @@unique([granularity, bucketStart, metricKey, dimension])
  @@index([bucketStart])
}

// @deprecated-write-path — the public "Təklif ver" submission widget was removed from the product
// (POST /api/suggestions no longer exists), so no new rows are created. Kept, not dropped, because
// GET /api/suggestions (admin-only) still reads existing rows for the admin panel and doubles as
// AdminGate's key-validation check; a future controlled migration can drop this table once the
// admin panel itself is retired.
model Suggestion {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  category  String // Funksionallıq | Dizayn | Qiymət | Digər
  text      String
  email     String
}
