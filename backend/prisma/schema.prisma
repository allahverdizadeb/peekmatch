// PeekMatch — CV/vacancy matching platform
// Prisma schema: analyses (CV + vacancy + AI result) and orders (one-time package purchases)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Analysis {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  expiresAt DateTime

  // Anonymous-session ownership (no user registration exists in this product — see
  // AnonymousSession below). Nullable so pre-migration rows remain readable (treated as
  // ownerless/public, matching their pre-migration behavior) — every newly-created analysis always
  // gets one via the session middleware.
  anonymousSessionId String?
  anonymousSession    AnonymousSession? @relation(fields: [anonymousSessionId], references: [id], onDelete: SetNull)

  // Paid-entitlement window, anchored to the FIRST successful payment for this analysis — separate
  // from `expiresAt` (the CV/vacancy *data retention* clock, which starts at creation for a free
  // analysis). Set once, atomically, the first time any Order for this analysis reaches 'paid';
  // later package upgrades do not reset it. See lib/pricing.ts's isEntitlementActive().
  paidAt               DateTime?
  entitlementExpiresAt DateTime?

  // CV input
  cvMode     String? // 'file' | 'text'
  cvFileName String?
  cvMimeType String?
  cvSizeBytes Int?
  cvText     String? // extracted / pasted CV text

  // Vacancy input
  vacancySource   String? // 'url' | 'manual'
  vacancyUrl      String?
  vacancyStatus   String  @default("idle") // idle | loading | success | failed
  vacancyFailReason String?
  vacancyTitle    String?
  vacancyCompany  String?
  vacancyLocation String?
  vacancyDomain   String?
  vacancyText     String? // extracted or manually pasted requirements text

  outputLanguage String  @default("az") // az | en
  consent        Boolean @default(false)

  // Processing
  status      String @default("draft") // draft | processing | done | failed
  procStage   Int    @default(0) // 0..6
  failReason  String?

  // AI result (free + paid derived content), stored as JSON
  resultJson         String? // matching analysis result (incl. cvPresentationScore)
  reportJson          String? // unused — /report is derived directly from resultJson, see analyses.ts
  cvChangePlanJson    String? // CV Change Plan (evidence-based rewrite/add/clarify/remove cards) — generated eagerly for every analysis, full list gated by unlocksApplication
  interviewPrepJson   String? // paid: Interview Playbook content

  // Interview Playbook generation job status — persisted (not just in-memory) so it survives a
  // server restart and so "processing" vs "failed" is a real, queryable fact rather than inferred
  // from an HTTP response. idle -> processing -> done | failed. A failed job can be retried, which
  // flips it back to processing; interviewPrepJson (above) is the actual result, set only on done.
  interviewPrepStatus     String  @default("idle") // idle | processing | done | failed
  interviewPrepFailReason String?

  // Lifecycle
  deletedAt                DateTime? // set by user-triggered delete; content fields nulled at the same time
  selfAttestedGapConfirmed Boolean?  // user's yes/no answer to "do you actually have this experience?" for mostImportantMissingRequirement
  selfAttestedGapDetails   String?   // free-text elaboration captured when the answer is "yes"

  // @deprecated — Cover Letter feature removed (product update). No longer read/written by any
  // application code; kept as-is rather than dropped to avoid a destructive migration on rows that
  // may still hold generated content (they self-expire within 24h regardless via the existing
  // retention cron, so this is safe to actually drop in a later cleanup pass once confirmed unused).
  coverLetterJson String?

  // @deprecated — CV Recheck feature removed (product update). Same non-destructive rationale as
  // coverLetterJson above: no longer read/written anywhere, left in place rather than dropped.
  recheckCvText     String?
  recheckResultJson String?
  recheckCount      Int     @default(0)

  orders         Order[]
  recoveryTokens RecoveryToken[]

  @@index([expiresAt])
  @@index([anonymousSessionId])
}

// Identifies "this browser" without registration — see middleware/anonymousSession.ts. The raw
// token only ever exists in the HttpOnly cookie on the client and in transit; only its SHA-256
// hash is stored here, so a database read can never yield a usable session token.
model AnonymousSession {
  id         String   @id @default(uuid())
  tokenHash  String   @unique
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())
  expiresAt  DateTime // sliding window, refreshed on use — deliberately longer-lived than any one
  // analysis's own 24h entitlement, since the session represents the returning browser, not a
  // single purchase.

  analyses Analysis[]

  @@index([expiresAt])
}

model Order {
  id         String   @id @default(uuid())
  createdAt  DateTime @default(now())
  paidAt     DateTime?
  analysisId String
  analysis   Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  package   Int // 1 = Application Package (CV Change Plan + Evidence Chain), 2 = Interview Ready Package (adds Interview Playbook)
  amountUsd Float
  status    String @default("pending") // pending | processing | paid | failed

  @@index([analysisId])
}

// Single-purpose "return to my paid analysis" link, sent by email after a successful payment (see
// routes/recovery.ts). Only the hash of the raw token is stored — same rationale as
// AnonymousSession.tokenHash — so the link itself is the only place the usable secret ever exists.
// consumedAt is intentionally NOT set on use (see routes/recovery.ts) — the token stays valid
// (re-openable, e.g. from multiple devices or repeat email opens) until the analysis's own
// entitlement expires; it is a bounded-lifetime bookmark, not a one-time-use credential.
model RecoveryToken {
  id         String   @id @default(uuid())
  tokenHash  String   @unique
  analysisId String
  analysis   Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  expiresAt  DateTime // mirrors Analysis.entitlementExpiresAt at issuance time

  @@index([analysisId])
}

// Minimal first-party product-analytics event log (no CV/document content, only ids/counts/booleans).
model Event {
  id         String   @id @default(uuid())
  createdAt  DateTime @default(now())
  name       String
  analysisId String?
  metadata   String? // JSON-encoded, small fixed key allowlist per event — see routes/events.ts

  @@index([name])
}

// @deprecated-write-path — the public "Təklif ver" submission widget was removed from the product
// (POST /api/suggestions no longer exists), so no new rows are created. Kept, not dropped, because
// GET /api/suggestions (admin-only) still reads existing rows for the admin panel and doubles as
// AdminGate's key-validation check; a future controlled migration can drop this table once the
// admin panel itself is retired.
model Suggestion {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  category  String // Funksionallıq | Dizayn | Qiymət | Digər
  text      String
  email     String
}
